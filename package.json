{
  "name": "typescript-starter-telegram",
  "version": "1.0.0",
  "description": "A TypeScript starter template for Telegram bots using grammY.",
  "type": "commonjs",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "webpack --config webpack.config.cjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:debug": "vitest --run --inspect-brk"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "grammy": "^1.38.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "copy-webpack-plugin": "^13.0.1",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-bundle": "^1.0.18",
    "vitest": "^4.0.18",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1"
  },
  "author": "Your Name",
  "license": "MIT"
}
